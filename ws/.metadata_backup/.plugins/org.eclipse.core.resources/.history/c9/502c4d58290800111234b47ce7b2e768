/* USER CODE BEGIN 4 */
void HAL_TIM_OC_DelayElapsedCallback(TIM_HandleTypeDef *htim)
{
    if (htim->Instance == TIM2)
    {
        switch (tim_state)
        {
            case 0: // *** Heartbeat 10Hz (Idle) ***
                // ครบกำหนด 100ms ปกติ -> สั่งอ่าน ADC
                // (ADC จะไปคำนวณและเช็ค Trigger ใน Callback ของมันเอง)
                HAL_ADC_Start_DMA(&hadc1, (uint32_t*)adc_buffer, 40);

                // ตั้งเวลาปลุกครั้งหน้าอีก 100ms (รักษาจังหวะ 10Hz)
                next_event_time += 100000;
                break;

            case 1: // *** จบช่วง Low 100ms ***
                // ดีดขึ้น High (เริ่ม Pulse N)
                HAL_GPIO_WritePin(GPIOA, GPIO_PIN_5, GPIO_PIN_SET);

                // ตั้งเวลาถัดไป = N + 100 us
                next_event_time += (N_Fan + 100);
                tim_state = 2; // ไป state ต่อไป
                break;

            case 2: // *** จบช่วง High N ***
                // ดึงลง Low (เริ่ม Pulse M)
                HAL_GPIO_WritePin(GPIOA, GPIO_PIN_5, GPIO_PIN_RESET);

                // ตั้งเวลาถัดไป = M + 100 us
                next_event_time += (M_Light + 100);
                tim_state = 3; // ไป state ต่อไป
                break;

            case 3: // *** จบช่วง Low M (จบ Pulse) ***
                HAL_GPIO_WritePin(GPIOA, GPIO_PIN_5, GPIO_PIN_SET); // กลับ High

                tim_state = 0;
                pulse_active = 0; // ปลดล็อค

                // --- จุดที่ต้องแก้ ---
                // ของเดิม: next_event_time += 100000; (รออีก 100ms ทำให้ช้า)

                // ของใหม่: รอแค่ 1ms พอ เพื่อให้ระบบหายใจ แล้วรีบกลับไปอ่าน ADC ต่อเลย
                next_event_time += 1000;

                break;

        // อัปเดตเวลาเป้าหมายลงใน Register
        __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_1, next_event_time);
    }
}

// ----------------------------------------------------------------------------
// Part B: ADC Interrupt Handler (คำนวณค่าและสั่ง Trigger)
// ถูกเรียกเมื่ออ่านค่า ADC เสร็จ (ซึ่งถูกสั่งมาจาก State 0 ด้านบน)
// ----------------------------------------------------------------------------
void HAL_ADC_ConvCpltCallback(ADC_HandleTypeDef* hadc)
{
    if (hadc->Instance == ADC1)
    {
        // 1. หาค่าเฉลี่ย
        uint32_t sum[4] = {0};
        for (int i = 0; i < 40; i++) sum[i % 4] += adc_buffer[i];
        for(int i=0; i<4; i++) adc_avg[i] = sum[i] / 10;

        // 2. แปลงหน่วย
        M_Light     = (adc_avg[0] * 2000) / 4095; // CH0
        N_Fan       = (adc_avg[1] * 500) / 4095;  // CH1
        val_TempSet = 20 + ((adc_avg[2] * 20) / 4095);
        internal_temp = __HAL_ADC_CALC_TEMPERATURE(3300, adc_avg[3], ADC_RESOLUTION_12B);

        // 3. Check Trigger
        if ((abs((int)N_Fan - (int)last_NFan) > 5 || abs((int)M_Light - (int)last_MLight) > 5) && pulse_active == 0)
        {
            last_NFan = N_Fan;
            last_MLight = M_Light;

            pulse_active = 1; // ล็อคไว้
            tim_state = 1;    // เข้าสู่ State รอจบ 100ms

            // 1. ดึงขาลง Low ทันที
            HAL_GPIO_WritePin(GPIOA, GPIO_PIN_5, GPIO_PIN_RESET);

            // 2. ตั้งเวลา Timer ใหม่: เอาเวลาปัจจุบัน + 100ms
            // (เป็นการ Override เวลาเดิมที่ตั้งไว้ใน State 0)
            next_event_time = __HAL_TIM_GET_COUNTER(&htim2) + 100000;
            __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_1, next_event_time);
        }
    }
}
